<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IscaeAnnuaire.Views.EnseignantsPage"
             Title="Enseignants"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,Auto,*">

        <Frame Grid.Row="0" BackgroundColor="White" Padding="10" Margin="10,10,10,5" CornerRadius="10">
            <StackLayout Spacing="8">
                <SearchBar x:Name="SearchBar"
                           Placeholder="Rechercher un enseignant..."
                           TextChanged="OnSearchChanged"
                           BackgroundColor="White"/>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Picker x:Name="PickerDept" Grid.Column="0"
                            Title="Département" TextColor="Black" TitleColor="Gray"
                            SelectedIndexChanged="OnFiltreChanged">
                        <Picker.Items>
                            <x:String>Tous</x:String>
                            <x:String>MED</x:String>
                            <x:String>MQI</x:String>
                        </Picker.Items>
                    </Picker>

                    <Picker x:Name="PickerGrade" Grid.Column="1"
                            Title="Grade" TextColor="Black" TitleColor="Gray"
                            SelectedIndexChanged="OnFiltreChanged">
                        <Picker.Items>
                            <x:String>Tous</x:String>
                            <x:String>Maître Assistant</x:String>
                            <x:String>Maître de Conférences</x:String>
                            <x:String>Professeur Habilité</x:String>
                            <x:String>Technologue</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>
            </StackLayout>
        </Frame>

        <Label Grid.Row="1" x:Name="LblCount" Margin="15,0" FontSize="12" TextColor="Gray"/>

        <ListView Grid.Row="2" x:Name="EnseignantsList"
                  ItemTapped="OnEnseignantTapped"
                  SeparatorVisibility="None"
                  HasUnevenRows="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Frame Margin="10,5" CornerRadius="12" BackgroundColor="White" Padding="15">
                            <Grid ColumnSpacing="15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Frame Grid.Column="0" BackgroundColor="#1B2A6B"
                                       CornerRadius="25" HeightRequest="50" WidthRequest="50" Padding="0">
                                    <Label Text="{Binding Prenom, StringFormat='{0:0}'}"
                                           TextColor="White" FontSize="20" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Frame>

                                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                    <Label FontSize="15" FontAttributes="Bold" TextColor="#1B2A6B">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="Prenom"/>
                                                <Binding Path="Nom"/>
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label Text="{Binding Grade}" FontSize="12" TextColor="#2ECC71"/>
                                    <Label Text="{Binding DepartementNom}" FontSize="11" TextColor="Gray"/>
                                </StackLayout>

                                <Label Grid.Column="2" Text="›" FontSize="24"
                                       TextColor="#1B2A6B" VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</ContentPage>
