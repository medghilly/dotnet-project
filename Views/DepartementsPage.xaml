<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IscaeAnnuaire.Views.DepartementsPage"
             Title="Départements"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <StackLayout Padding="15" Spacing="15">

            <!-- Département MED -->
            <Border BackgroundColor="#1B2A6B"
                    StrokeShape="RoundRectangle 15"
                    Stroke="Transparent"
                    Padding="20">
                <StackLayout Spacing="10">
                    <Label Text="MED" FontSize="28" FontAttributes="Bold"
                           TextColor="#2ECC71" HorizontalOptions="Center"/>
                    <Label Text="Management, Economie et Droit"
                           FontSize="14" TextColor="White" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="1" BackgroundColor="#2ECC71" Margin="0,5"/>

                    <Label Text="Filières Licence" FontSize="13"
                           TextColor="#2ECC71" FontAttributes="Bold"/>
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12">
                        <StackLayout Spacing="8">
                            <Label Text="• Banques &amp; Assurances" TextColor="#333" FontSize="13"/>
                            <Label Text="• Finance &amp; Comptabilité" TextColor="#333" FontSize="13"/>
                            <Label Text="• Gestion des Ressources Humaines" TextColor="#333" FontSize="13"/>
                            <Label Text="• Techniques Commerciales et Marketing" TextColor="#333" FontSize="13"/>
                        </StackLayout>
                    </Border>

                    <Label Text="Filières Master" FontSize="13"
                           TextColor="#2ECC71" FontAttributes="Bold"/>
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12">
                        <Label Text="• Master Pro. Finance et Comptabilité"
                               TextColor="#333" FontSize="13"/>
                    </Border>
                </StackLayout>
            </Border>

            <!-- Département MQI -->
            <Border BackgroundColor="#1B2A6B"
                    StrokeShape="RoundRectangle 15"
                    Stroke="Transparent"
                    Padding="20">
                <StackLayout Spacing="10">
                    <Label Text="MQI" FontSize="28" FontAttributes="Bold"
                           TextColor="#2ECC71" HorizontalOptions="Center"/>
                    <Label Text="Méthodes Quantitatives et Informatiques"
                           FontSize="14" TextColor="White" HorizontalOptions="Center"/>
                    <BoxView HeightRequest="1" BackgroundColor="#2ECC71" Margin="0,5"/>

                    <Label Text="Filières Licence" FontSize="13"
                           TextColor="#2ECC71" FontAttributes="Bold"/>
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12">
                        <StackLayout Spacing="8">
                            <Label Text="• Développement Informatique" TextColor="#333" FontSize="13"/>
                            <Label Text="• Informatique de Gestion" TextColor="#333" FontSize="13"/>
                            <Label Text="• Réseaux Informatiques et Télécommunications" TextColor="#333" FontSize="13"/>
                            <Label Text="• Statistique Appliquée à l'Economie" TextColor="#333" FontSize="13"/>
                        </StackLayout>
                    </Border>

                    <Label Text="Filières Master" FontSize="13"
                           TextColor="#2ECC71" FontAttributes="Bold"/>
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 10"
                            Stroke="Transparent" Padding="12">
                        <Label Text="• Master Pro. Informatique Appliquée à la Gestion"
                               TextColor="#333" FontSize="13"/>
                    </Border>
                </StackLayout>
            </Border>

        </StackLayout>
    </ScrollView>
</ContentPage>
